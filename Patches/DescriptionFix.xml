<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Update the ability description -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/AbilityDef[defName="WVC_Archiver_Integrator"]/description</xpath>
    <value>
      <description>Dismantle the target into atoms, reassembling it as part of the archiver gene forms. Can only target downed pawns.</description>
    </value>
  </Operation>

  <!-- Update the CD -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/AbilityDef[defName="WVC_Archiver_Integrator"]/cooldownTicksRange</xpath>
    <value>
      <cooldownTicksRange>0</cooldownTicksRange>
    </value>
  </Operation>

  <!-- Update the gene's custom effect description bullet point -->
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/GeneDef[defName="WVC_Archiver_Integrator"]/customEffectDescriptions/li[contains(.,'opinion')]</xpath>
    <value>
      <li>Can only target a &lt;color=#8a8ae6&gt;downed&lt;/color&gt; pawn.</li>
    </value>
  </Operation>

</Patch>